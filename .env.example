# ============================================================
# Content Factory — YupSoul Configuration
# Copy to .env.local and fill in your values
# ============================================================

# --- Vercel Cron Secret (generate with: openssl rand -hex 32) ---
CRON_SECRET=

# --- Brand ---
BRAND_NAME="YupSoul"
BRAND_DESCRIPTION="Telegram Mini App — персонализированные AI-музыкальные композиции на основе астрологического профиля. Космическая мелодия твоей души."
BRAND_TARGET_AUDIENCE="Женщины 18-40, интересующиеся астрологией, самопознанием, AI-технологиями и персонализированными подарками"
BRAND_TONE=mystical
# Options: expert, friendly, provocative, informative, humorous, mystical
BRAND_TOPICS="звук_знака,реакции_на_трек,совместимость,энергия_дня,астро_факты,знаки_как_жанры,подарок,backstage_ai,ретроград,мемы_знаков,медитация,сравни_трек,знаменитости,полнолуние,история_астро_музыки,батл_знаков,утренний_ритуал,туториал,отзывы,cosmic_news"
BRAND_COLOR_PRIMARY="#2D1B69"
BRAND_COLOR_SECONDARY="#1A1A3E"
BRAND_COLOR_ACCENT="#D4A574"
BRAND_LANGUAGE=ru
# Options: ru, en, both
BRAND_LOGO_URL=
BRAND_SITE_URL=https://www.yupsoul.online/
BRAND_BOT_URL=https://t.me/Yup_Soul_bot?start=ref_miplix
BRAND_BOT_DISPLAY=@Yup_Soul_bot

# --- LLM Text Generation (priority: free first) ---
# Option 1: Google Gemini (FREE — 1000 req/day Flash-Lite, 250/day Flash)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Option 2: DeepSeek (FREE — 500M tokens/month)
DEEPSEEK_API_KEY=

# Option 3: Ollama local (FREE, unlimited — requires local GPU)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:7b

# Option 4: Anthropic Claude (paid ~$10-50/mo)
ANTHROPIC_API_KEY=

# Option 5: OpenAI (paid)
OPENAI_API_KEY=

# --- Image Generation ---
# Option 1: Stability AI ($0.003/image)
STABILITY_API_KEY=

# Option 2: Replicate (pay-per-use, Flux models)
REPLICATE_API_KEY=

# --- TTS / Voice (Russian) ---
# Option 1: Fish Audio (200 min/mo FREE)
FISH_AUDIO_API_KEY=

# Option 2: ElevenLabs (10K chars/mo free)
ELEVENLABS_API_KEY=

# --- Platforms ---
# Telegram (primary — FREE, no limits)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_REPORT_CHAT_ID=

# YouTube (FREE — ~6 uploads/day)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Instagram (FREE — requires Business account + Meta App Review)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# TikTok (FREE — requires developer review)
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# VK (FREE — generous limits)
VK_ACCESS_TOKEN=
VK_GROUP_ID=

# X/Twitter (pay-per-use since Feb 2026 — lowest priority)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# --- Storage ---
# Cloudflare R2 (10GB FREE, $0 egress)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=yupsoul-media

# --- Schedule (MSK timezone) ---
SCHEDULE_TIMEZONE=Europe/Moscow
SCHEDULE_POSTS_PER_DAY=telegram:3,instagram:1,tiktok:2,youtube:1,vk:1
SCHEDULE_PUBLISH_TIMES=telegram:09:00,15:00,20:00;instagram:11:00;tiktok:12:00,22:00;youtube:14:00;vk:13:00
